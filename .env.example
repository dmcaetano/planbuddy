# PlanBuddy environment configuration
# Copy to .env and fill in real values for local/dev use.
# Nothing in this file is a secret; do not commit a filled-in .env.

# --- Server ---
PORT=4000
NODE_ENV=development

# Cookie signing secret. Generate a random 32+ byte string for real deployments.
SESSION_SECRET=dev-only-change-me-please-use-a-long-random-string

# --- Database ---
# If unset, the server falls back to an embedded local PGlite database
# (zero setup, data stored under ./.data/planbuddy). Set this to a real
# Postgres connection string (e.g. a Neon URL) to use a real database.
# DATABASE_URL=postgres://user:password@host/db?sslmode=require
# Dedicated namespace inside a shared Neon database. Lowercase letters,
# numbers, and underscores only.
DB_SCHEMA=planbuddy

# --- AI (DeepSeek via OpenRouter) ---
# If unset, PlanBuddy uses a deterministic local "demo AI" that fabricates
# schema-valid candidates without any network call, so the app is fully
# usable with zero external keys.
# OPENROUTER_API_KEY=sk-or-...
MODEL_ID=deepseek/deepseek-v4-flash

# --- Optional live place resolver ---
# When unset, PlanBuddy runs in explicit "Inspiration mode": recommendations
# name permanent geography and categories but never invent specific venue
# facts (hours, open/closed status).
# PLACE_RESOLVER_API_KEY=

# --- Weather ---
# Open-Meteo requires no API key.
